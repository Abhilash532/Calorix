rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isCreator() {
      return isAuthenticated() && request.auth.token.email == 'aabhi20604@gmail.com';
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'height', 'weight', 'age', 'activityLevel', 'goal']) &&
             data.uid == request.auth.uid &&
             data.height is number &&
             data.weight is number &&
             data.age is number;
    }

    function isValidDailyLog(data) {
      return data.uid == request.auth.uid &&
             data.date is string &&
             data.items is list;
    }

    function isValidRecipe(data) {
      return data.keys().hasAll(['name', 'calories', 'protein', 'carbs', 'fats', 'authorUid']) &&
             data.name is string &&
             data.calories is number &&
             data.authorUid == request.auth.uid;
    }

    // Rules
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
    }
    
    match /daily_logs/{logId} {
      allow read: if isAuthenticated() && logId.split('_')[0] == request.auth.uid;
      allow create: if isAuthenticated() && logId.split('_')[0] == request.auth.uid && isValidDailyLog(request.resource.data);
      allow update: if isAuthenticated() && logId.split('_')[0] == request.auth.uid && isValidDailyLog(request.resource.data);
      allow delete: if isAuthenticated() && logId.split('_')[0] == request.auth.uid;
    }
    
    match /recipes/{recipeId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidRecipe(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.authorUid == request.auth.uid && isValidRecipe(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']))
      );
      allow delete: if isAuthenticated() && resource.data.authorUid == request.auth.uid;
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /cheers/{cheerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
